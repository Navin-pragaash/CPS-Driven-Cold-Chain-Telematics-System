#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/adc.h"
#include "esp_adc_cal.h"

// Constants
#define ADC_CHANNEL ADC1_CHANNEL_0       // GPIO36 (VP)
#define ADC_WIDTH ADC_WIDTH_BIT_12       // 12-bit resolution
#define ADC_ATTEN ADC_ATTEN_DB_0         // 0dB attenuation (0-1.1V range)
#define DEFAULT_VREF 1100                // Default reference voltage in mV
#define BUFFER_SIZE 8000                 // Buffer size for 1 second of audio at 8kHz sampling rate

// Variables for ADC calibration
static esp_adc_cal_characteristics_t *adc_chars;

// Buffer to store ADC readings
static uint16_t adc_buffer[BUFFER_SIZE];

// Function to initialize ADC and calibration
void init_adc()
{
    // Configure ADC width (resolution)
    adc1_config_width(ADC_WIDTH);

    // Configure ADC channel and attenuation
    adc1_config_channel_atten(ADC_CHANNEL, ADC_ATTEN);

    // Allocate memory for calibration characteristics
    adc_chars = calloc(1, sizeof(esp_adc_cal_characteristics_t));

    // Perform ADC calibration
    esp_adc_cal_characterize(ADC_UNIT_1, ADC_ATTEN, ADC_WIDTH, DEFAULT_VREF, adc_chars);

    printf("ADC Initialized and Calibrated.\n");
}

// Task to read ADC values and store them in the buffer
void adc_read_task(void *arg)
{
    int index = 0;

    while (1)
    {
        // Read raw ADC value
        uint32_t raw_adc = adc1_get_raw(ADC_CHANNEL);

        // Convert raw ADC value to calibrated voltage (mV)
        uint32_t voltage = esp_adc_cal_raw_to_voltage(raw_adc, adc_chars);

        // Store the raw value in the buffer
        adc_buffer[index] = raw_adc;

        // Print the calibrated voltage (for debugging)
        printf("Raw ADC: %d, Voltage: %d mV\n", raw_adc, voltage);

        // Increment buffer index (circular buffer)
        index = (index + 1) % BUFFER_SIZE;

        // Delay to control sampling rate (8kHz)
        vTaskDelay(pdMS_TO_TICKS(1)); // 1ms delay (~1000 Hz per task execution)
    }
}

void app_main()
{
    // Initialize ADC and calibration
    init_adc();

    // Create a task to read ADC values
    xTaskCreate(adc_read_task, "ADC Read Task", 4096, NULL, 5, NULL);
}



